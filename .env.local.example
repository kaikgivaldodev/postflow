# Supabase (Settings → API no painel do projeto)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Meta / Instagram (developers.facebook.com)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/instagram/callback

# SyncPay
SYNCPAY_API_KEY=
SYNCPAY_WEBHOOK_SECRET=

# Criptografia dos access_tokens do Instagram (AES-256, 32 bytes em base64)
# Gerar com: openssl rand -base64 32
ENCRYPTION_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@postflow.app

# Rate limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
